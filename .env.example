# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Finnhub
FINNHUB_API_KEY=your_finnhub_key

# Server
PORT=3000
NODE_ENV=development

# Kronos Mode: mock | native | python
# mock   → zufällige realistische Scores (für Tests)
# native → Claude analysiert Candlestick-Daten direkt
# python → ruft externen Kronos-Python-Server auf
KRONOS_MODE=native
KRONOS_PYTHON_URL=http://localhost:5001/predict

# Paper Trading
PAPER_TRADING_START_BALANCE=1000
PAPER_TRADING_MAX_POSITION=100
PAPER_TRADING_MIN_FINAL_SCORE=65
PAPER_TRADING_MIN_CONFIDENCE=65
PAPER_TRADING_HOLD_HOURS=24

# Reddit (User Agent Pflicht)
REDDIT_USER_AGENT=Nostrad/1.0

# Telegram (optional, für Daily Report)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

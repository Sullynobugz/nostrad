{
  "name": "nostrad",
  "version": "0.1.0",
  "description": "Personal Paper-Trading Research System — Event + Sentiment + Polymarket + Kronos",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && npm --prefix apps/dashboard ci && npm --prefix apps/dashboard run build",
    "start": "node dist/index.js",
    "close-trades": "ts-node src/paperTrading/closer.ts",
    "daily-report": "ts-node src/reports/dailyReport.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@supabase/supabase-js": "^2.49.4",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "rss-parser": "^3.13.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
